
<!-- ADMIN "Manage Appointments" EJS -->

<%- include("includes/_header") %>

<% if (error) { %>
  <div class="alert"><strong>Error:</strong> <%= error %></div>
<% } %>

<!--Navigation Bar-->
<header>
  <%- include("includes/_navbar") %>
</header>

  <br> 
  <button type="button" id="notifs">Notifications</button>

  <!-- Appointment/cancellation buttons -->
  <button type="button" id="cancelBtn">Cancel Appointment</button>

  <br><br>

  <!-- Search Appointments box/search function -->
  <input id="search" type="text" placeholder="Search appointments..." />

  <%

function formatTo12Hour(timeStr) {
  if (!timeStr) return "No time";

  const [hourStr, minute] = timeStr.split(":");
  let hour = parseInt(hourStr, 10);

  const ampm = hour >= 12 ? "PM" : "AM";

  hour = hour % 12;
  if (hour === 0) hour = 12;

  return `${hour}:${minute} ${ampm}`;
}
%>
  
  <!-- Appointments Table -->
<div style="display: flex; gap: 20px;"> <!-- BEGIN FLEX -->
  <div style="flex: 1;">
  <table border="1" cellpadding="6" cellspacing="0" style="margin-top:10px;">
    <thead>
      <tr>
          <!-- headers (1st row) -->

        <th>Select</th>
        <th>Date</th>
        <th>Time</th>
        <th>Student Name</th>
        <th>Tutor Name</th>
        <th>Course</th>
      </tr>
    </thead>

    <tbody id="rows">
    <!-- checking if appointments exist -->
      <% if (appointments && appointments.length > 0) { %>
        <!-- looping through appointments-->
    <% appointments.forEach(function(appointment) { %>
      <tr>
        <!-- radio button instead of checkbox -> only one appt selected at a time to cancel or assign tutor-->
    <td><input type="radio" name="selectedAppointment" value="<%= appointment._id %>"> </td> 
    <!-- if appointment date exists, convert to string (using .split to get 00:00:000Z from mongodb date)-->
        <td><%= appointment.appointmentDate ? appointment.appointmentDate.toISOString().split('T')[0] : "No date" %></td>
        <!-- printing start time and endtime-->
        <td>  <%= formatTo12Hour(appointment.startTime) %> -  <%= formatTo12Hour(appointment.endTime) %> </td>
        <!-- -->
        <td>
          <!-- if student id/firstName exists -->
          <% if (appointment.studentId && appointment.studentId.fname) { %>
            <!-- print first and last name-->
            <%= appointment.studentId.fname %> <%= appointment.studentId.lname %>
          <% } else { %>
            <!-- print fallback (to avoid crashing) -->
            Unknown student
          <% } %>
        </td>
        <!-- -->
        <td>
          <!-- if tutor shift id exists/tutorId/first name,-->
          <% if (
            appointment.tutorShiftId &&
            appointment.tutorShiftId.tutorId &&
            appointment.tutorShiftId.tutorId.fname
          ) { %>
          <!-- print tutor first and last name-->
            <%= appointment.tutorShiftId.tutorId.fname %>
            <%= appointment.tutorShiftId.tutorId.lname %>
          <% } else { %>
            <!-- print fallback (to avoid crashing) -->

            No tutor assigned
          <% } %>
        </td>
        <!-- prints course name-->
        <td><%= appointment.course %></td>

      </tr>
    <% }); %>
    <% } else { %>
    <tr>
      <td colspan="6">No appointments found.</td>
    </tr>
    <% } %>
  </tbody>
</table>
</div>


<div id="notificationsModal" style ="display:none; background: #eee; padding: 30px;">
  
  <h3>Notifications</h3>
  
  <button id="closeNotificationsBtn">Close</button>

  <table border ="1">
    <thead>
      <tr>
        <th>Time</th>
        <th>Details</th>
        </tr>
      </thead>
    
      <tbody>
        <% if (notificationLogs && notificationLogs.length > 0) { %> 
          <% notificationLogs.forEach(function(notification) { %> 
            <tr>
              <td>
                <%= notification.timestamp ? new Date(notification.timestamp).toLocaleString() : "No time" %>
                </td>
                
                <td>
                  Student
                  <%= notification.recipientUserId ? notification.recipientUserId.fname : "Unknown" %>
                  booked an appointment on 
                  <%= notification.appointmentDate ? new Date(notification.appointmentDate).toISOString().split('T')[0] : "No date" %>
                  </td>
                </tr>
                <% }) %>
                <% } else { %> 
                  <tr> 
                    <td colspan="2">No notifications</td>
                    </tr>
               <% } %>
        </tbody>
    </table>
  
  </div>




  <!-- Cancellation History Modal -->
   <!-- modal fixed (no-scroll), darkended bg when opened-->
  <div id="historyModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,.35); padding:30px;">
   
    <div style="background:#fff; padding:12px; max-width:900px; margin:0 auto;">
      <div style="display:flex; justify-content:space-between; align-items:center;">
     <h3 style="margin:0;">Cancellation History</h3>
        <button type="button" id="closeHistoryBtn">X</button>
      </div>
<!-- styling table margin/width, modify later in separate css-->
      <table border="1" cellpadding="6" cellspacing="0" style="margin-top:10px; width:100%;">
        <thead>
          <tr>
            <th>Canceled At</th>
            <th>Date</th>
            <th>Time</th>
            <th>Student</th>
           <th>Tutor</th>
            <th>Course</th>
          </tr>
        </thead>
           <tbody id="historyRows"></tbody>
      </table>
  <!--Admin's Google Calendar-->
  <div style="flex: 1;">
  <div id="googleCalendarView">
  <iframe src="https://calendar.google.com/calendar/embed?height=600&wkst=1&ctz=America%2FChicago&showPrint=0&src=aXN1dHV0b3JhZG1pbkBnbWFpbC5jb20&src=ZW4udXNhI2hvbGlkYXlAZ3JvdXAudi5jYWxlbmRhci5nb29nbGUuY29t&color=%23039be5&color=%230b8043" style="border:solid 1px #777" width="800" height="600" frameborder="0" scrolling="no"></iframe>
  </div>
  <a href="https://calendar.google.com/calendar/u/4?cid=aXN1dHV0b3JhZG1pbkBnbWFpbC5jb20" style="align-content: end;">Having trouble seeing the Google Calendar? Click here to view full calendar.</a>
  </div>
</div> <!-- END FLEX -->

    <!-- Confirm Cancel Modal -->
  <div id="confirmCancelModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,.35); padding:30px;">
  <div style="background:#fff; padding:12px; max-width:400px; margin:0 auto;">
    <h3>Confirm Cancellation</h3>
    <p>Are you sure you want to cancel this appointment?</p>
    <form action="/adminIndex/cancelAppointment" method="POST">
      <input type="hidden" name="appointmentId" id="confirmAppointmentId">
      <button type="submit">Yes, Cancel</button>
      <button type="button" id="closeConfirmBtn">No</button>
    </form>
  </div>
</div>

<script src="/js/adminIndex.js"></script>

<%- include("includes/_footer") %>
