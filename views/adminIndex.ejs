<%- include("includes/_header") %>

<% if (error) { %>
  <div class="alert"><strong>Error:</strong> <%= error %></div>
<% } %>

<!--Navigation Bar-->
<header>
  <%- include("includes/_navbar") %>
</header>

  <br> 
    <button type="button" id="notifs">Notifications</button>


  <!-- Appointment/cancellation buttons -->
  <button type="button" id="addBtn">Add Appointment</button>
  <button type="button" id="cancelBtn">Cancel Appointment</button>
  <button type="button" id="historyBtn">Cancellation History</button>
  <button type="button" id="assignTutorBtn">Assign Tutor</button>


  <!-- Adding Appointments form -->

  <!-- Form appears when "Add Appointment" is clicked-->
<form id="addForm" action="/adminIndex/findTutors" method="GET" style="display:none; margin-top:10px;">
  <input name="studentFName" type="text" placeholder="Student First Name" required>
  <input name="studentLName" type="text" placeholder="Student Last Name" required>
  <input name="date" type="date" required>
  <input name="time" type="time" required>

 <!-- Course dropdown (dynamically populated from db!)-->
  <select name="course" required>
    <!--default placeholder of courses-->
  <option value="" disabled selected>Select Course</option>
  <!-- Looping through course array (passed from cont.)-->
  <% courses.forEach(course => { %>
    <!-- passing each course as an option (in dropdown menu)-->
     <!-- note to self, value = course's db id-->
  <option value="<%= course._id %>"><%= course.courseName %></option>
<% }) %>
</select>

  <button type="submit">Find Tutors</button>
</form>


<!-- AFTER SUBMISSION (clicking the "Find Tutors" button above)
 A DROPDOWN SHOULD BE POPULATED showing all tutors available 
 to be assigned to the chosen appointment (and/or showing that selected appointment 
 is not valid/all tutors are not available during selected appointment range?) 
 If appointment range is valid, admin should then choose a tutor from dropdown 
 and click a final "save" button which adds/creates appointment-->
    </select>

    <button type="submit">Save</button>
  </form>

  <br><br>




  <!-- Search Appointments box/search function -->
  <input id="search" type="text" placeholder="Search appointments..." />

  <!-- Appointments Table -->
  <table border="1" cellpadding="6" cellspacing="0" style="margin-top:10px;">
    <thead>
      <tr>
          <!-- headers (1st row) -->

        <th>Select</th>
        <th>Date</th>
        <th>Time</th>
        <th>Student Name</th>
        <th>Tutor Name</th>
        <th>Course</th>
      </tr>
    </thead>

    <tbody id="rows">
 <!-- checking if appointments exist -->
      <% if (appointments && appointments.length > 0) { %>
        <!-- looping through appointments-->
    <% appointments.forEach(function(appointment) { %>
      <tr>
        <!-- radio button instead of checkbox -> only one appt selected at a time to cancel or assign tutor-->
    <td><input type="radio" name="selectedAppointment" value="<%= appointment._id %>"> </td> 
    <!-- if appointment date exists, convert to string (using .split to get 00:00:000Z from mongodb date)-->
        <td><%= appointment.appointmentDate ? appointment.appointmentDate.toISOString().split('T')[0] : "No date" %></td>
        <!-- printing start time and endtime-->
        <td><%= appointment.startTime %> - <%= appointment.endTime %></td>
        <!-- -->
        <td>
          <!-- if student id/firstName exists -->
          <% if (appointment.studentId && appointment.studentId.fname) { %>
            <!-- print first and last name-->
            <%= appointment.studentId.fname %> <%= appointment.studentId.lname %>
          <% } else { %>
            <!-- print fallback (to avoid crashing) -->
            Unknown student
          <% } %>
        </td>
<!-- -->
        <td>
          <!-- if tutor shift id exists/tutorId/first name,-->
  <% if (
    appointment.tutorShiftId &&
    appointment.tutorShiftId.tutorId &&
    appointment.tutorShiftId.tutorId.fname
  ) { %>
    <!-- print tutor first and last name-->
    <%= appointment.tutorShiftId.tutorId.fname %>
    <%= appointment.tutorShiftId.tutorId.lname %>
  <% } else { %>
     <!-- print fallback (to avoid crashing) -->

    No tutor assigned
  <% } %>
</td>
<!-- prints course name-->
        <td><%= appointment.course %></td>

      </tr>
    <% }); %>
  <% } else { %>
    <tr>
      <td colspan="6">No appointments found.</td>
    </tr>
  <% } %>
</tbody>
  </table>




  <!-- Cancellation History Modal -->
   <!-- modal fixed (no-scroll), darkended bg when opened-->
  <div id="historyModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,.35); padding:30px;">
   
    <div style="background:#fff; padding:12px; max-width:900px; margin:0 auto;">
      <div style="display:flex; justify-content:space-between; align-items:center;">
     <h3 style="margin:0;">Cancellation History</h3>
        <button type="button" id="closeHistoryBtn">X</button>
      </div>
<!-- styling table margin/width, modify later in separate css-->
      <table border="1" cellpadding="6" cellspacing="0" style="margin-top:10px; width:100%;">
        <thead>
          <tr>
            <th>Canceled At</th>
            <th>Date</th>
            <th>Time</th>
            <th>Student</th>
           <th>Tutor</th>
            <th>Course</th>
          </tr>
        </thead>
           <tbody id="historyRows"></tbody>
      </table>
  </div>
  </div>

<%- include("includes/_footer") %>
