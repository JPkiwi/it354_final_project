
<!-- ADMIN "Manage Availability" EJS -->

<%- include("includes/_header") %>


<!--Navigation Bar-->
<header>
  <%- include("includes/_navbar") %>
</header>

<main class= "pageContent" >
  
  
<div class="errorContainer">
  <% if (error) { %>
    <div class="errorMessage">
      <%= error %>
    </div>
  <% } %>
</div>


  <h1 class="visually-hidden">Manage Availability</h1>

  <div class="adminAvailabilityLayout">
  
    <div class="availabilityFunctionality">
        <!--Admin availability button options-->
      <div class="adminAvailabilityButtons">
        <button class = "small-red-button-round" type="button" id="editHoursButton">Edit Center Hours</button>
        <button class = "small-red-button-round" type="button" id="editExceptionButton">Add Exception</button>
        <button class = "small-red-button-round" type="button" id="editBlackoutButton">Add Blackout Date</button>
        <button class = "small-red-button-round" type="button" id="removeExceptionsButton">Remove Blackout Date / Exception</button>
      </div>

      <!--Admin change general center hours hours-->
      <div class="changeHours">
        <form id="changeHoursForm" action="/changeHours" method="post" style="display: none;"> <!--Initially hidden-->
          <label class ="modalText" for="selectWeekday">Select Day of the Week:</label>
          <select name="weekday" id="weekday" required>
            <option value="Monday">Monday</option>
            <option value="Tuesday">Tuesday</option>
            <option value="Wednesday">Wednesday</option>
            <option value="Thursday">Thursday</option>
            <option value="Friday">Friday</option>
            <option value="Saturday">Saturday</option>
            <option value="Sunday">Sunday</option>
          </select>

          <br />
          <br />
          
          <label class ="modalText" id="center-open-label" for="centerOpenTime">Open Time:</label>
          <input class = "inputFunc"  type="time" id="centerOpenTime" name="centerOpenTime" step="3600" />
          <label class ="modalText" id="center-close-label" for="centerCloseTime">Close Time:</label>
          <input class = "inputFunc"  type="time" id="centerCloseTime" name="centerCloseTime" step="3600" />
          <br /> 
          <br>
          <strong >Note:</strong> On the hour is required to change center hours.
          <br />
          <br />
          <label class ="modalText" id="close-weekday-label" for="closeWeekdayDropdown">Close this day? </label>
          <select name="closeWeekdayDropdown" id="closeWeekdayDropdown" required >
            <option value="No">No</option>
            <option value="Yes">Yes</option>
          </select>
          <br />
          <br />

          <button class = "small-red-button-round" type="submit" id="submitHoursButton">Submit Hours</button>
        </form>
      </div>

      
      <div class = "addBlackoutDate">
        <form id="blackoutDateForm" action = "/addBlackoutDate" method = "POST" style = "display: none;">
          <label class = "modalText" for="blackoutStartDate">Start Date: </label>
          <input type = "text" id = "blackoutStartDate" name = "startDate" required />

          <label class = "modalText" for="blackoutEndDate">End Date: </label>
          <input type = "text" id = "blackoutEndDate" name = "endDate" required />

          <br> 
          <br>
          <label class = "modalText" for = "blackoutReason">Reason: </label>
          <input class = "inputFunc"  type = "text" id = "blackoutReason" name="reason" required /> 
          <br>
          <br>
          <button class = "small-red-button-round" type="submit">Submit Blackout Date</button>

        </form>
      </div> 


      <div class="addException">
        <form id="exceptionForm" action="/addException" method="POST" style="display: none;">
          <label class = "modalText" for="exceptionDate">Date:</label>
          <input type="text" id="exceptionDate" name="exceptionDate" required />

          <br>
          <br>

          <label class = "modalText" for="exceptionStartTime">Start Time:</label>
          <input class = "inputFunc"  type="time" id="exceptionStartTime" name="startTime" step="3600" required />

          <br>
          <br>

          <label class = "modalText" for="exceptionEndTime">End Time:</label>
          <input class = "inputFunc"  type="time" id="exceptionEndTime" name="endTime" step="3600" required />

          <br>
          <br>

          <strong>Note:</strong> Enter exception times on the hour (e.g., 2:00 – 4:00 PM) to indicate when the center will be closed.
          
          <br>
          <br>

          <label class = "modalText" for="exceptionReason">Reason:</label>
          <input class = "inputFunc" type="text" id="exceptionReason" name="reason" required />

          <br>
          <br>

          <button class = "small-red-button-round" type="submit">Submit Exception</button>
        </form>
      </div>

      <div class="removeExceptions">
        <form id="removeExceptionsForm" action="/removeExceptions" method="POST" style="display: none;">
          
          <label class = "modalText" for="removeExceptionDate">Date:</label>
          <input type="text" id="removeExceptionDate" name="removeExceptionDate" required />

          <br><br>

          <button class = "small-red-button-round" id="removeExceptSubmitBtn" type="submit">Submit Removal</button>
        </form>
      </div>



    </div>

  </div>

  <div class="calendar-hours-row">
    <div class="google-blackout-calendar">
      <iframe src="https://calendar.google.com/calendar/embed?src=87bf4cf19fff65dfeb231ab88f47d24867a89d47245cc83c778657a81a12814b%40group.calendar.google.com&ctz=America%2FChicago" style="border: 0" width="800" height="600" frameborder="0" scrolling="no"></iframe>
    </div>
    <div class="generalCenterHours">
    <% 
        // retrieve current date/time to determine if center is currently open or closed
        const today = new Date();

        // get weekday index from current date (0 = Sunday, 6 = Saturday)
        const weekdayIndex = today.getDay();

        // since getDay indexes 0 = Sunday, 6 = Saturday, move the indices around to match the weekdays in application
        // (this was why open/closed wasn't working originally)
        const weekdayIndices = [6, 0, 1, 2, 3, 4, 5];

        // get current hour
        const currHour = today.getHours();

        // get the matching weekday object from the weekdays array using the proper index for our application weekday order
        const currWeekday = weekdays[weekdayIndices[weekdayIndex]];

        // declare open and close hour so they can be used outside the if block below
        let openHour, closeHour;

        // only split/store open and close times if the center is not closed that day
        if (currWeekday && !currWeekday.isClosed && currWeekday.timeBlocks.length > 0) {
            const firstBlock = currWeekday.timeBlocks[0];
            const lastBlock = currWeekday.timeBlocks[currWeekday.timeBlocks.length - 1];

            // get open and close hour as an integer
            openHour = Number(firstBlock.start.split(":")[0]);
            closeHour = Number(lastBlock.end.split(":")[0]);
        }
    %>

    <h2 class = "headingText" style="margin-top: 0;">This Week's Center Hours:</h2>
      <!--Display the day of the week and the open and closed hours, in AM/PM-->
      <% weekdays.forEach(day => { %>
        <h3 class = "modalText" style="margin: 10px 0;">
          <span class = "boldText"><%= day.weekday %>: </span>
          <% if (day.isClosed || !day.timeBlocks || day.timeBlocks.length === 0) { %>
            Closed
          <% } else { %>
            <% day.timeBlocks.forEach((block, i) => { %>
              <%= formatTo12Hour(block.start) %> - <%= formatTo12Hour(block.end) %>
              <% if (i < day.timeBlocks.length - 1) { %>
                <br>
              <% } %>
            <% }) %>

          <% } %>
        </h3>
      <% }) %>
    </div>
  </div>

</main> 

<script id="page-data" type="application/json">
  <%- JSON.stringify({ closedWeekdays }) %>
</script>

<!-- Flatpickr CDN (if not already in your header) -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/flatpickr/dist/flatpickr.min.css">
<script src="https://cdn.jsdelivr.net/npm/flatpickr"></script>


<%- include("includes/_footer") %>
