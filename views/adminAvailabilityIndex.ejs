  <div class="adminAvailabilityLayout">
  
  <div class="availabilityFunctionality">
    <!--Admin availability button options-->
  <div class="adminAvailabilityButtons">
    <button type="button" id="editHoursButton">Edit Hours</button>
    <button type="button" id="addTimeButton">Add Time Block</button>
    <button type="button" id="editExceptionButton">Add Exception</button>
    <button type="button" id="editBlackoutButton">Add Blackout Date</button>
  </div>

  <!--Admin change general center hours hours-->
  <div class="changeHours">
    <form id="changeHoursForm" action="/changeHours" method="post" style="display: none;"> <!--Initially hidden-->
      <label for="selectWeekday">Select Day of the Week:</label>
      <select name="weekday" id="weekday" required>
        <option value="Monday">Monday</option>
        <option value="Tuesday">Tuesday</option>
        <option value="Wednesday">Wednesday</option>
        <option value="Thursday">Thursday</option>
        <option value="Friday">Friday</option>
        <option value="Saturday">Saturday</option>
        <option value="Sunday">Sunday</option>
      </select>

      <br />
      <br />
      
      <label id="center-open-label" for="centerOpenTime">Open Time:</label>
      <input type="time" id="centerOpenTime" name="centerOpenTime" step="3600" />
      <label id="center-close-label" for="centerCloseTime">Close Time:</label>
      <input type="time" id="centerCloseTime" name="centerCloseTime" step="3600" />
      <br />
      <strong>Note:</strong> On the hour is required to change center hours.
      <br />
      <br />
      <label id="close-weekday-label" for="closeWeekdayDropdown">Close this day? </label>
      <select name="closeWeekdayDropdown" id="closeWeekdayDropdown" required >
        <option value="No">No</option>
        <option value="Yes">Yes</option>
      </select>
      <br />
      <br />

      <button type="submit" id="submitHoursButton">Submit Hours</button>
    </form>
  </div>



  
<div class = "addBlackoutDate">
  <form id="blackoutDateForm" action = "/addBlackoutDate" method = "POST" style = "display: none;">
    <label for="blackoutStartDate">Start Date: </label>
    <input type = "text" id = "blackoutStartDate" name = "startDate" required />

    <br> 
    <br>
    <label for="blackoutEndDate">End Date: </label>
    <input type = "text" id = "blackoutEndDate" name = "endDate" required />

    <br> 
    <br>
    <label for = "blackoutReason">Reason: </label>
    <input type = "text" id = "blackoutReason" name="reason" required /> 
    <br>
    <br>
    <button type="submit">Submit Blackout Date</button>

  </form>
  


</div> 





  </div>

  <div class="generalCenterHours">
    <% 
        // retrieve current date/time to determine if center is currently open or closed
        const today = new Date();

        // get weekday index from current date (0 = Sunday, 6 = Saturday)
        const weekdayIndex = today.getDay();

        // since getDay indexes 0 = Sunday, 6 = Saturday, move the indices around to match the weekdays in application
        // (this was why open/closed wasn't working originally)
        const weekdayIndices = [6, 0, 1, 2, 3, 4, 5];

        // get current hour
        const currHour = today.getHours();

        // get the matching weekday object from the weekdays array using the proper index for our application weekday order
        const currWeekday = weekdays[weekdayIndices[weekdayIndex]];

        // declare open and close hour so they can be used outside the if block below
        let openHour, closeHour;

        // only split/store open and close times if the center is not closed that day
        if (currWeekday && !currWeekday.isClosed) {
            // get open hour as an integer
            openHour = Number(currWeekday.openTime.split(":")[0]);

            // get close hour as an integer
            closeHour = Number(currWeekday.closeTime.split(":")[0]);
        }
    %>

    <h1 style="margin-top: 0;">General Center Hours:</h1>
        <!--Display the day of the week and the open and closed hours, in AM/PM-->
        <% weekdays.forEach(day => { %>
            <h3 style="margin: 10px 0;">
                <%= day.weekday %>:
                <% if(day.isClosed){ %>
                    Closed
                <% } else { %>
                    <% 
                        const [openHour, openMinute] = day.openTime.split(":");
                        const [closeHour, closeMinute] = day.closeTime.split(":");
                        let openHourNum = parseInt(openHour);
                        let closeHourNum = parseInt(closeHour);
                        const openAMPM = openHourNum >= 12 ? "PM" : "AM";
                        const closeAMPM = closeHourNum >= 12 ? "PM" : "AM";
                        openHourNum = openHourNum % 12 || 12;
                        closeHourNum = closeHourNum % 12 || 12;
                    %>
                    <%= openHourNum + ":" + openMinute + " " + openAMPM + " - " + closeHourNum + ":" + closeMinute + " " + closeAMPM %>
                <% } %>
            </h3>
        <% }) %>
  </div>

</div>


<%- include("includes/_footer") %>
