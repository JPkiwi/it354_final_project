<%- include("includes/_header") %>

<% if (error) { %>
  <div class="alert"><strong>Error:</strong> <%= error %></div>
<% } %>

<!--Navigation Bar-->
<header>
  <%- include("includes/_navbar") %>
</header>

<div class = "headlinerContainer">
    <h1>Welcome to the IT Learning Center!</h1>
    <br />
    <h2>Get ready to learn with us!</h2>
    <div class="buttonRow">
    <div class="loginButton">
        <form action="/login" method="get">
        <button type="submit">Login</button>
        </form>
    </div>
    </div>
</div>

<div class = "whySection">
    <h2>Why Use the IT Tutoring Center?</h2>

 <div class = "reasons">
    <h3>1. Personalized Support</h3>
    <p>Get one-on-one help tailored to your specific questions and learning pace, 
        so you're never left behind.</p>
    <h3>2. Flexible Scheduling</h3>
    <p>Book appointments around your schedule with available time slots that fit your day.</p>
    <h3>3. Expert Tutors</h3>
    <p>Work with knowledgeable tutors who have hands-on experience in the subject matter and 
        are here to help you succeed.</p>
 </div>
</div>

<section aria-label="Photo Gallery">
    <div class = "carousel" data-carousel>
        <button class = "carousel-button prev" data-carousel-button="prev">&#10508;</button>
        <button class = "carousel-button next" data-carousel-button="next">&#10509;</button>
    <ul data-slides>
        <li class = "slide" data-active>
            <img src = "/images/oldunion1.jpg" alt = "Old Union Building">
        </li>
        <li class = "slide">
            <img src = "/images/isuseal2.jpg" alt = "ISU Seal">
        </li>
        <li class = "slide">
            <img src = "/images/stockPhoto3.jpg" alt = "Women teaching Girl Stock Image">
        </li>
        <li class = "slide">
            <img src = "/images/stockPhoto4.jpg" alt = "Technology Stock Image">
        </li>
    </ul>
    </div>
</section>

<div class = "hoursAndLocation">
    <!--Create Javascript toggle for open/closed-->
    <h2>We are currently OPEN / CLOSED</h2>
    <div class = "hoursRow">
    <div class = "hours">
